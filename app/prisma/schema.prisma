generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientType {
  BUSINESS
  RESIDENTIAL
}

enum AssetStatus {
  ACTIVE
  RETIRING
  SUNSET
}

enum AssetCategory {
  NETWORK_GEAR
  WIRELESS
  SERVER
  NAS
  COMPUTER
  LAPTOP
  TABLET
  PRINTER
  PHONE_SYSTEM
  PHONE_ENDPOINT
  WEBSITE
  VPN
  OTHER
}

enum LocationRelation {
  PRIMARY
  OCCASIONAL
  REMOTE
}

enum AlarmSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlarmStatus {
  ACTIVE
  DISMISSED
  RESOLVED
}

enum ActivityEventType {
  ASSET_ADDED
  ASSET_RETIRED
  ASSET_UPDATED
  CREDENTIAL_ROTATED
  LICENSE_CHANGED
  USER_ADDED
  USER_REMOVED
  ALARM_TRIGGERED
  TECH_NOTE
  SITE_VISIT
  KNOWN_ISSUE
  PLANNED_MAINTENANCE
  API_SYNC
}

enum UserRole {
  ADMIN
  TECH
  CLIENT
}

enum VendorCategory {
  ISP
  SOFTWARE
  HARDWARE
  TELECOM
  CLOUD
  SECURITY
  SERVICES
  OTHER
}

enum NetworkDeviceType {
  SWITCH
  FIREWALL
  ROUTER
  ACCESS_POINT
  NAS
  UPS
  MODEM
  OTHER
}

model StaffUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  role         UserRole  @default(TECH)
  microsoftId  String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activityEvents ActivityEvent[]
}

model Client {
  id        String     @id @default(cuid())
  name      String
  type      ClientType @default(BUSINESS)
  syncroId  String?    @unique
  notes     String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  locations      Location[]
  users          ClientUser[]
  credentials    Credential[]
  licenses       License[]
  applications   Application[]
  contacts       Contact[]
  alarms         Alarm[]
  activityEvents ActivityEvent[]
  vendors        Vendor[]        @relation("ClientVendors")
  websites       Website[]
  networkDevices NetworkDevice[]
  subnets        Subnet[]
}

model Location {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  address   String?
  city      String?
  state     String?
  zip       String?
  ispName   String?
  wanIp     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client        Client         @relation(fields: [clientId], references: [id])
  assets        Asset[]
  userLocations UserLocation[]
  networkDevices NetworkDevice[]
  racks         Rack[]
  subnets       Subnet[]
}

model ClientUser {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  email     String?
  phone     String?
  m365Upn   String?
  jobTitle  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client        Client         @relation(fields: [clientId], references: [id])
  userLocations UserLocation[]
  assets        Asset[]        @relation("AssetPrimaryUser")
  licenses      License[]      @relation("LicenseAssignedUser")
  applications  Application[]  @relation("ApplicationAssignedUser")
  credentials   Credential[]   @relation("CredentialUser")
  ipAssignments IpAssignment[] @relation("UserIpAssignment")
}

model UserLocation {
  id         String           @id @default(cuid())
  userId     String
  locationId String
  relation   LocationRelation @default(PRIMARY)

  user     ClientUser @relation(fields: [userId], references: [id])
  location Location   @relation(fields: [locationId], references: [id])

  @@unique([userId, locationId])
}

model AssetType {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[]
}

model Asset {
  id             String        @id @default(cuid())
  locationId     String
  primaryUserId  String?
  assetTypeId    String?
  contactId      String?
  category       AssetCategory @default(OTHER)
  status         AssetStatus   @default(ACTIVE)
  name           String
  make           String?
  model          String?
  serial         String?
  assetTag       String?
  ipAddress      String?
  macAddress     String?
  vlan           String?
  switchPort     String?
  managementUrl  String?
  splashtopUrl   String?
  purchaseDate   DateTime?
  warrantyExpiry DateTime?
  room           String?
  syncroAssetId  String?       @unique
  notes          String?
  successorId    String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  location      Location      @relation(fields: [locationId], references: [id])
  primaryUser   ClientUser?   @relation("AssetPrimaryUser", fields: [primaryUserId], references: [id])
  assetType     AssetType?    @relation(fields: [assetTypeId], references: [id])
  contact       Contact?      @relation("AssetContact", fields: [contactId], references: [id])
  credentials   Credential[]
  exitInterview ExitInterview?
  successor     Asset?        @relation("AssetSuccessor", fields: [successorId], references: [id])
  predecessor   Asset?        @relation("AssetSuccessor")
  rackSlots     RackSlot[]    @relation("AssetRackSlot")
  ipAssignments IpAssignment[] @relation("AssetIpAssignment")
}

model ExitInterview {
  id        String   @id @default(cuid())
  assetId   String   @unique
  reason    String
  retiredBy String
  retiredAt DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])
}

model Credential {
  id                String    @id @default(cuid())
  clientId          String
  assetId           String?
  userId            String?
  contactId         String?
  label             String
  username          String?
  encryptedPassword String
  url               String?
  notes             String?
  isRetired         Boolean   @default(false)
  lastRotated       DateTime?
  expiryDate        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  client   Client      @relation(fields: [clientId], references: [id])
  asset    Asset?      @relation(fields: [assetId], references: [id])
  user     ClientUser? @relation("CredentialUser", fields: [userId], references: [id])
  contact  Contact?    @relation("CredentialContact", fields: [contactId], references: [id])
}

model License {
  id             String    @id @default(cuid())
  clientId       String
  assignedUserId String?
  contactId      String?
  vendorId       String?
  name           String
  vendor         String?
  licenseKey     String?
  seats          Int?
  assignedSeats  Int?
  purchaseDate   DateTime?
  expiryDate     DateTime?
  renewalDate    DateTime?
  cost           Float?
  pax8Id         String?
  notes          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client       Client      @relation(fields: [clientId], references: [id])
  assignedUser ClientUser? @relation("LicenseAssignedUser", fields: [assignedUserId], references: [id])
  contact      Contact?    @relation("LicenseContact", fields: [contactId], references: [id])
  vendorRef    Vendor?     @relation(fields: [vendorId], references: [id])
}

model Application {
  id             String   @id @default(cuid())
  clientId       String
  assignedUserId String?
  contactId      String?
  vendorId       String?
  name           String
  vendor         String?
  version        String?
  supportUrl     String?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client       Client      @relation(fields: [clientId], references: [id])
  assignedUser ClientUser? @relation("ApplicationAssignedUser", fields: [assignedUserId], references: [id])
  contact      Contact?    @relation("ApplicationContact", fields: [contactId], references: [id])
  vendorRef    Vendor?     @relation(fields: [vendorId], references: [id])
}

model Contact {
  id              String   @id @default(cuid())
  clientId        String
  syncroContactId String?  @unique
  name            String
  role            String?
  email           String?
  phone           String?
  mobile          String?
  isPrimary       Boolean  @default(false)
  isBilling    Boolean  @default(false)
  isEscalation Boolean  @default(false)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client      Client        @relation(fields: [clientId], references: [id])
  assets      Asset[]       @relation("AssetContact")
  licenses    License[]     @relation("LicenseContact")
  applications Application[] @relation("ApplicationContact")
  credentials Credential[]  @relation("CredentialContact")
}

model Alarm {
  id              String        @id @default(cuid())
  clientId        String
  severity        AlarmSeverity @default(INFO)
  status          AlarmStatus   @default(ACTIVE)
  type            String
  message         String
  details         String?
  visibleToClient Boolean       @default(false)
  dismissedAt     DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id])
}

model ActivityEvent {
  id              String            @id @default(cuid())
  clientId        String
  staffUserId     String?
  eventType       ActivityEventType
  title           String
  body            String?
  isPinned        Boolean           @default(false)
  visibleToClient Boolean           @default(false)
  dismissedAt     DateTime?
  createdAt       DateTime          @default(now())

  client    Client     @relation(fields: [clientId], references: [id])
  staffUser StaffUser? @relation(fields: [staffUserId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  ext_expires_in    Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vendor {
  id            String         @id @default(cuid())
  name          String
  category      VendorCategory @default(OTHER)
  website       String?
  supportUrl    String?
  supportPhone  String?
  supportEmail  String?
  accountNumber String?
  portalUrl     String?
  notes         String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  clients      Client[]        @relation("ClientVendors")
  contacts     VendorContact[]
  applications Application[]
  licenses     License[]
}

model Website {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  label         String?
  domain        String
  registrar     String?
  registrarUrl  String?
  accountNumber String?
  autoRenew     Boolean   @default(false)
  expiresAt     DateTime?
  sslExpiresAt  DateTime?
  sslIssuer     String?
  lastChecked   DateTime?
  dnsRecords    Json?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @default(now())
}

model VendorContact {
  id        String   @id @default(cuid())
  vendorId  String
  name      String
  role      String?
  email     String?
  phone     String?
  mobile    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model NetworkDevice {
  id              String            @id @default(cuid())
  clientId        String
  locationId      String?
  name            String
  type            NetworkDeviceType @default(OTHER)
  make            String?
  model           String?
  ipAddress       String?
  macAddress      String?
  serial          String?
  firmwareVersion String?
  managementUrl   String?
  notes           String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  client    Client      @relation(fields: [clientId], references: [id])
  location  Location?   @relation(fields: [locationId], references: [id])
  rackSlots RackSlot[]
}

model Rack {
  id         String   @id @default(cuid())
  locationId String
  name       String
  totalU     Int      @default(42)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  slots    RackSlot[]
}

model RackSlot {
  id              String   @id @default(cuid())
  rackId          String
  startU          Int
  heightU         Int      @default(1)
  label           String?
  networkDeviceId String?
  assetId         String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rack          Rack           @relation(fields: [rackId], references: [id], onDelete: Cascade)
  networkDevice NetworkDevice? @relation(fields: [networkDeviceId], references: [id], onDelete: SetNull)
  asset         Asset?         @relation("AssetRackSlot", fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([rackId, startU])
}

model Subnet {
  id          String   @id @default(cuid())
  clientId    String
  locationId  String?
  cidr        String
  gateway     String?
  dns1        String?
  dns2        String?
  vlan        String?
  description String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client        Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  location      Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  ipAssignments IpAssignment[]
}

model IpAssignment {
  id         String   @id @default(cuid())
  subnetId   String
  ipAddress  String
  hostname   String?
  assetId    String?
  userId     String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  subnet  Subnet      @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  asset   Asset?      @relation("AssetIpAssignment", fields: [assetId], references: [id], onDelete: SetNull)
  user    ClientUser? @relation("UserIpAssignment", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([subnetId, ipAddress])
}
