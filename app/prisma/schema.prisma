enum AssetCategory {
  NETWORK_GEAR
  WIRELESS
  SERVER
  NAS
  COMPUTER
  LAPTOP
  TABLET
  PRINTER
  PHONE_SYSTEM
  PHONE_ENDPOINT
  WEBSITE
  VPN
  OTHER
