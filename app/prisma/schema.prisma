generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StaffUser {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  role           UserRole        @default(TECH)
  microsoftId    String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  activityEvents ActivityEvent[]
  vpnAccess      VpnAccessor[]   @relation("StaffUserVpnAccess")
  apiKeys        ApiKey[]
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  staffUserId String
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  staffUser   StaffUser @relation(fields: [staffUserId], references: [id])
}

model Client {
  id             String             @id @default(cuid())
  name           String
  type           ClientType         @default(BUSINESS)
  syncroId       String?            @unique
  notes          String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  activityEvents ActivityEvent[]
  alarms         Alarm[]
  applications   Application[]
  attachments    ClientAttachment[]
  documents      ClientDocument[]
  users          ClientUser[]
  contacts       Contact[]
  credentials    Credential[]
  licenses       License[]
  locations      Location[]
  networkDevices NetworkDevice[]
  runbooks       Runbook[]
  subnets        Subnet[]
  vlans          Vlan[]
  websites       Website[]
  vendors        Vendor[]           @relation("ClientVendors")
  adDomains      AdDomain[]
  networkShares  NetworkShare[]
  vpnGateways    VpnGateway[]
  phoneSystems   PhoneSystem[]
  cameraSystems  CameraSystem[]
  wifiControllers WifiController[]
}

model Location {
  id             String          @id @default(cuid())
  clientId       String
  name           String
  address        String?
  city           String?
  state          String?
  zip            String?
  ispName        String?
  wanIp          String?
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assets         Asset[]
  client         Client          @relation(fields: [clientId], references: [id])
  networkDevices NetworkDevice[]
  racks          Rack[]
  subnets        Subnet[]
  userLocations  UserLocation[]
}

model ClientUser {
  id            String         @id @default(cuid())
  clientId      String
  name          String
  email         String?
  phone         String?
  m365Upn       String?
  jobTitle      String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  applications  Application[]  @relation("ApplicationAssignedUser")
  assets        Asset[]        @relation("AssetPrimaryUser")
  client        Client         @relation(fields: [clientId], references: [id])
  credentials   Credential[]   @relation("CredentialUser")
  ipAssignments IpAssignment[] @relation("UserIpAssignment")
  licenses      License[]      @relation("LicenseAssignedUser")
  userLocations UserLocation[]
  vpnAccess        VpnAccessor[]    @relation("ClientUserVpnAccess")
  phoneExtensions  PhoneExtension[] @relation("ClientUserExtension")
}

model UserLocation {
  id         String           @id @default(cuid())
  userId     String
  locationId String
  relation   LocationRelation @default(PRIMARY)
  location   Location         @relation(fields: [locationId], references: [id])
  user       ClientUser       @relation(fields: [userId], references: [id])

  @@unique([userId, locationId])
}

model AssetType {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assets      Asset[]
}

model Asset {
  id             String         @id @default(cuid())
  locationId     String
  primaryUserId  String?
  category       AssetCategory  @default(OTHER)
  status         AssetStatus    @default(ACTIVE)
  name           String
  make           String?
  model          String?
  serial         String?
  assetTag       String?
  ipAddress      String?
  macAddress     String?
  vlan           String?
  switchPort     String?
  managementUrl  String?
  purchaseDate   DateTime?
  warrantyExpiry DateTime?
  room           String?
  syncroAssetId  String?        @unique
  notes          String?
  successorId    String?        @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  splashtopUrl   String?
  driverUrl      String?
  friendlyName   String?
  isFavorite     Boolean  @default(false)
  rdpEnabled     Boolean  @default(false)
  rdpHost        String?
  rdpPort        Int?
  vncEnabled     Boolean  @default(false)
  vncHost        String?
  vncPort        Int?
  assetTypeId    String?
  contactId      String?
  dataSource     String         @default("MANUAL")
  assetType      AssetType?     @relation(fields: [assetTypeId], references: [id])
  contact        Contact?       @relation("AssetContact", fields: [contactId], references: [id])
  location       Location       @relation(fields: [locationId], references: [id])
  primaryUser    ClientUser?    @relation("AssetPrimaryUser", fields: [primaryUserId], references: [id])
  successor      Asset?         @relation("AssetSuccessor", fields: [successorId], references: [id])
  predecessor    Asset?         @relation("AssetSuccessor")
  credentials    Credential[]
  exitInterview  ExitInterview?
  ipAssignments  IpAssignment[]  @relation("AssetIpAssignment")
  rackSlots      RackSlot[]      @relation("AssetRackSlot")
  networkShares    NetworkShare[]   @relation("AssetNetworkShare")
  interfaces       AssetInterface[]
  vpnGateways      VpnGateway[]     @relation("AssetVpnGateway")
  phoneSystems     PhoneSystem[]    @relation("AssetPhoneSystem")
  phoneExtensions  PhoneExtension[] @relation("AssetPhoneExtension")
  cameraSystems    CameraSystem[]   @relation("AssetCameraSystem")
  cameras          Camera[]         @relation("AssetCamera")
  wifiControllers  WifiController[] @relation("AssetWifiController")
}

model ExitInterview {
  id        String   @id @default(cuid())
  assetId   String   @unique
  reason    String
  retiredBy String
  retiredAt DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id])
}

model Credential {
  id                String      @id @default(cuid())
  clientId          String
  assetId           String?
  label             String
  username          String?
  encryptedPassword String
  encryptedTotp     String?
  url               String?
  notes             String?
  isRetired         Boolean     @default(false)
  isFavorite        Boolean     @default(false)
  lastRotated       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  userId            String?
  contactId         String?
  expiryDate        DateTime?
  dataSource        String      @default("MANUAL")
  asset             Asset?       @relation(fields: [assetId], references: [id])
  client            Client       @relation(fields: [clientId], references: [id])
  contact           Contact?     @relation("CredentialContact", fields: [contactId], references: [id])
  user              ClientUser?  @relation("CredentialUser", fields: [userId], references: [id])
  vpnGateways          VpnGateway[]     @relation("CredentialVpnGateway")
  vpnAccessors         VpnAccessor[]    @relation("CredentialVpnAccessor")
  phoneSystems         PhoneSystem[]    @relation("CredentialPhoneSystem")
  phoneExtensions      PhoneExtension[] @relation("CredentialPhoneExtension")
  voicemailExtensions  PhoneExtension[] @relation("CredentialVoicemail")
  cameraSystems        CameraSystem[]   @relation("CredentialCameraSystem")
  wifiControllers      WifiController[] @relation("CredentialWifiController")
  wifiNetworks         WifiNetwork[]    @relation("CredentialWifiNetwork")
}

model License {
  id             String      @id @default(cuid())
  clientId       String
  name           String
  vendor         String?
  seats          Int?
  expiryDate     DateTime?
  renewalDate    DateTime?
  cost           Float?
  pax8Id         String?
  notes          String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  assignedUserId String?
  contactId      String?
  assignedSeats  Int?
  licenseKey     String?
  purchaseDate   DateTime?
  vendorId       String?
  dataSource     String      @default("MANUAL")
  billingTerm    String?
  status         String?
  assignedUser   ClientUser? @relation("LicenseAssignedUser", fields: [assignedUserId], references: [id])
  client         Client      @relation(fields: [clientId], references: [id])
  contact        Contact?    @relation("LicenseContact", fields: [contactId], references: [id])
  vendorRef      Vendor?     @relation(fields: [vendorId], references: [id])
}

model Application {
  id             String      @id @default(cuid())
  clientId       String
  name           String
  vendor         String?
  version        String?
  supportUrl     String?
  notes          String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  assignedUserId String?
  contactId      String?
  vendorId       String?
  assignedUser   ClientUser? @relation("ApplicationAssignedUser", fields: [assignedUserId], references: [id])
  client         Client      @relation(fields: [clientId], references: [id])
  contact        Contact?    @relation("ApplicationContact", fields: [contactId], references: [id])
  vendorRef      Vendor?     @relation(fields: [vendorId], references: [id])
}

model Contact {
  id              String        @id @default(cuid())
  clientId        String
  name            String
  role            String?
  email           String?
  phone           String?
  isPrimary       Boolean       @default(false)
  isBilling       Boolean       @default(false)
  isEscalation    Boolean       @default(false)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  mobile          String?
  syncroContactId String?       @unique
  applications    Application[] @relation("ApplicationContact")
  assets          Asset[]       @relation("AssetContact")
  client          Client        @relation(fields: [clientId], references: [id])
  credentials     Credential[]  @relation("CredentialContact")
  licenses        License[]     @relation("LicenseContact")
  vpnAccess       VpnAccessor[] @relation("ContactVpnAccess")
}

model Alarm {
  id              String        @id @default(cuid())
  clientId        String
  severity        AlarmSeverity @default(INFO)
  status          AlarmStatus   @default(ACTIVE)
  type            String
  message         String
  details         String?
  visibleToClient Boolean       @default(false)
  dismissedAt     DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client        @relation(fields: [clientId], references: [id])
}

model ActivityEvent {
  id              String            @id @default(cuid())
  clientId        String
  staffUserId     String?
  eventType       ActivityEventType
  title           String
  body            String?
  isPinned        Boolean           @default(false)
  visibleToClient Boolean           @default(false)
  dismissedAt     DateTime?
  createdAt       DateTime          @default(now())
  client          Client            @relation(fields: [clientId], references: [id])
  staffUser       StaffUser?        @relation(fields: [staffUserId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  ext_expires_in    Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vendor {
  id            String          @id @default(cuid())
  name          String
  website       String?
  supportUrl    String?
  supportPhone  String?
  supportEmail  String?
  accountNumber String?
  notes         String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  category      VendorCategory  @default(OTHER)
  portalUrl     String?
  applications  Application[]
  licenses      License[]
  contacts      VendorContact[]
  clients       Client[]        @relation("ClientVendors")
  vpnAccess     VpnAccessor[]   @relation("VendorVpnAccess")
}

model Website {
  id            String    @id @default(cuid())
  clientId      String
  label         String?
  domain        String
  registrar     String?
  expiresAt     DateTime?
  lastChecked   DateTime?
  dnsRecords    Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accountNumber String?
  autoRenew     Boolean   @default(false)
  notes         String?
  registrarUrl  String?
  sslExpiresAt  DateTime?
  sslIssuer     String?
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model ClientDocument {
  id          String             @id @default(cuid())
  clientId    String
  title       String
  content     String?
  category    String?
  isPinned    Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  attachments ClientAttachment[]
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientAttachment {
  id           String          @id @default(cuid())
  clientId     String
  documentId   String?
  originalName String
  storageName  String          @unique
  mimeType     String
  size         Int
  notes        String?
  createdAt    DateTime        @default(now())
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  document     ClientDocument? @relation(fields: [documentId], references: [id])
}

model RunbookCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String    @default("#6366f1")
  createdAt DateTime  @default(now())
  runbooks  Runbook[]
}

model RunbookTag {
  id        String          @id @default(cuid())
  name      String          @unique
  createdAt DateTime        @default(now())
  runbooks  RunbookTagMap[]
}

model Runbook {
  id          String           @id @default(cuid())
  title       String
  summary     String?
  content     String?
  categoryId  String?
  clientId    String?
  isPublished Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  category    RunbookCategory? @relation(fields: [categoryId], references: [id])
  client      Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  steps       RunbookStep[]
  tags        RunbookTagMap[]
}

model RunbookTagMap {
  runbookId String
  tagId     String
  runbook   Runbook    @relation(fields: [runbookId], references: [id], onDelete: Cascade)
  tag       RunbookTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([runbookId, tagId])
}

model RunbookStep {
  id        String   @id @default(cuid())
  runbookId String
  order     Int
  title     String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  runbook   Runbook  @relation(fields: [runbookId], references: [id], onDelete: Cascade)
}

model VendorContact {
  id        String   @id @default(cuid())
  vendorId  String
  name      String
  role      String?
  email     String?
  phone     String?
  mobile    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model NetworkDevice {
  id              String            @id @default(cuid())
  clientId        String
  locationId      String?
  name            String
  type            NetworkDeviceType @default(OTHER)
  make            String?
  model           String?
  ipAddress       String?
  macAddress      String?
  serial          String?
  firmwareVersion String?
  managementUrl    String?
  notes            String?
  portCount        Int?              // number of physical ports (switches)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  dataSource       String            @default("MANUAL")
  externalId       String?           // ID from external system (Unifi _id, Meraki serial, etc.)
  lastSeenAt       DateTime?
  uptime           Int?              // uptime in seconds
  connectedClients Int?              // number of connected clients (APs/switches)
  client           Client            @relation(fields: [clientId], references: [id])
  location         Location?         @relation(fields: [locationId], references: [id])
  rackSlots        RackSlot[]
  switchPorts      SwitchPort[]
  vpnGateways      VpnGateway[]      @relation("NetworkDeviceVpnGateway")
  wifiControllers  WifiController[]  @relation("NetworkDeviceWifiController")
}

model Vlan {
  id          String           @id @default(cuid())
  clientId    String
  vlanNumber  Int
  name        String
  color       String           @default("#6366f1")
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  client      Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  switchPorts SwitchPort[]
  interfaces  AssetInterface[]

  @@unique([clientId, vlanNumber])
}

model SwitchPort {
  id              String           @id @default(cuid())
  networkDeviceId String
  portNumber      Int
  label           String?
  isUplink        Boolean          @default(false)
  vlanId          String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  networkDevice   NetworkDevice    @relation(fields: [networkDeviceId], references: [id], onDelete: Cascade)
  vlan            Vlan?            @relation(fields: [vlanId], references: [id])
  interfaces      AssetInterface[]

  @@unique([networkDeviceId, portNumber])
}

model AssetInterface {
  id           String      @id @default(cuid())
  assetId      String
  name         String      // e.g. "eth0", "NIC 1", "Management", "iDRAC"
  macAddress   String?
  ipAddress    String?
  vlanId       String?
  switchPortId String?
  isPrimary    Boolean     @default(false)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  asset        Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  vlan         Vlan?       @relation(fields: [vlanId], references: [id])
  switchPort   SwitchPort? @relation(fields: [switchPortId], references: [id])
}

model Rack {
  id         String     @id @default(cuid())
  locationId String
  name       String
  totalU     Int        @default(42)
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  location   Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  slots      RackSlot[]
}

model RackSlot {
  id              String         @id @default(cuid())
  rackId          String
  startU          Int
  heightU         Int            @default(1)
  label           String?
  networkDeviceId String?
  assetId         String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  shelfPos        Int            @default(0)
  asset           Asset?         @relation("AssetRackSlot", fields: [assetId], references: [id])
  networkDevice   NetworkDevice? @relation(fields: [networkDeviceId], references: [id])
  rack            Rack           @relation(fields: [rackId], references: [id], onDelete: Cascade)

  @@unique([rackId, startU, shelfPos])
}

model Subnet {
  id            String         @id @default(cuid())
  clientId      String
  locationId    String?
  cidr          String
  gateway       String?
  dns1          String?
  dns2          String?
  vlan          String?
  description   String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  ipAssignments IpAssignment[]
  wifiNetworks  WifiNetwork[]
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  location      Location?      @relation(fields: [locationId], references: [id])
}

model IpAssignment {
  id        String      @id @default(cuid())
  subnetId  String
  ipAddress String
  hostname  String?
  assetId   String?
  userId    String?
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  asset     Asset?      @relation("AssetIpAssignment", fields: [assetId], references: [id])
  subnet    Subnet      @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  user      ClientUser? @relation("UserIpAssignment", fields: [userId], references: [id])

  @@unique([subnetId, ipAddress])
}

enum ClientType {
  BUSINESS
  RESIDENTIAL
}

enum AssetStatus {
  ACTIVE
  RETIRING
  SUNSET
}

enum AssetCategory {
  NETWORK_GEAR
  WIRELESS
  SERVER
  NAS
  COMPUTER
  LAPTOP
  TABLET
  PRINTER
  PHONE_SYSTEM
  PHONE_ENDPOINT
  WEBSITE
  VPN
  OTHER
}

enum LocationRelation {
  PRIMARY
  OCCASIONAL
  REMOTE
}

enum AlarmSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlarmStatus {
  ACTIVE
  DISMISSED
  RESOLVED
}

enum ActivityEventType {
  ASSET_ADDED
  ASSET_RETIRED
  ASSET_UPDATED
  CREDENTIAL_ROTATED
  LICENSE_CHANGED
  USER_ADDED
  USER_REMOVED
  ALARM_TRIGGERED
  TECH_NOTE
  SITE_VISIT
  KNOWN_ISSUE
  PLANNED_MAINTENANCE
  API_SYNC
}

enum UserRole {
  ADMIN
  TECH
  CLIENT
}

enum VendorCategory {
  ISP
  SOFTWARE
  HARDWARE
  TELECOM
  CLOUD
  SECURITY
  SERVICES
  OTHER
}

enum NetworkDeviceType {
  SWITCH
  FIREWALL
  ROUTER
  ACCESS_POINT
  NAS
  UPS
  MODEM
  OTHER
}

model AdDomain {
  id              String         @id @default(cuid())
  clientId        String
  name            String         // e.g. corp.client.local
  netbiosName     String?        // e.g. CORP
  functionalLevel String?        // e.g. Windows Server 2019
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  groups          DomainGroup[]
  shares          NetworkShare[]
}

model DomainGroup {
  id          String            @id @default(cuid())
  domainId    String
  name        String            // e.g. Finance_Users
  scope       String?           // Global / Universal / Domain Local
  purpose     String?
  members     String[]          // samAccountNames
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  domain      AdDomain          @relation(fields: [domainId], references: [id], onDelete: Cascade)
  permissions SharePermission[]
}

model NetworkShare {
  id          String            @id @default(cuid())
  clientId    String
  domainId    String?
  assetId     String?           // file server / NAS asset
  name        String            // e.g. Finance
  uncPath     String            // e.g. \\FS01\Finance
  shareType   ShareType         @default(SMB)
  purpose     String?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  domain      AdDomain?         @relation(fields: [domainId], references: [id])
  asset       Asset?            @relation("AssetNetworkShare", fields: [assetId], references: [id])
  permissions SharePermission[]
}

model SharePermission {
  id            String          @id @default(cuid())
  shareId       String
  principal     String          // e.g. CORP\Finance_Users
  principalType PrincipalType   @default(GROUP)
  domainGroupId String?
  accessLevel   ShareAccess     @default(READ)
  layer         PermissionLayer @default(BOTH)
  notes         String?
  createdAt     DateTime        @default(now())
  share         NetworkShare    @relation(fields: [shareId], references: [id], onDelete: Cascade)
  domainGroup   DomainGroup?    @relation(fields: [domainGroupId], references: [id])
}

enum ShareType {
  SMB
  DFS
  NFS
}

enum PrincipalType {
  USER
  GROUP
  COMPUTER
}

enum ShareAccess {
  READ
  CHANGE
  FULL_CONTROL
  DENY
}

enum PermissionLayer {
  SHARE
  NTFS
  BOTH
}

model VpnGateway {
  id              String        @id @default(cuid())
  clientId        String
  assetId         String?       // Windows/Linux box hosting OpenVPN etc.
  networkDeviceId String?       // SonicWall, Meraki firewall, etc.
  credentialId    String?       // PSK or admin credential in vault
  name            String        // e.g. "OpenVPN Server", "SonicWall Global VPN"
  type            VpnType
  serverAddress   String?       // IP or hostname clients connect to
  port            Int?
  protocol        String?       // UDP / TCP
  serverConfig    String?       // server-side config blob (markdown/text)
  clientConfig    String?       // .ovpn template or profile blob
  notes           String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  asset           Asset?        @relation("AssetVpnGateway", fields: [assetId], references: [id])
  networkDevice   NetworkDevice? @relation("NetworkDeviceVpnGateway", fields: [networkDeviceId], references: [id])
  credential      Credential?   @relation("CredentialVpnGateway", fields: [credentialId], references: [id])
  accessors       VpnAccessor[]
}

model VpnAccessor {
  id             String          @id @default(cuid())
  gatewayId      String
  accessorType   VpnAccessorType
  clientUserId   String?
  vendorId       String?
  staffUserId    String?         // PCC tech accessing this client
  contactId      String?
  thirdPartyName String?         // fallback: "Ricoh copier tech"
  credentialId   String?         // their VPN credential/cert in vault
  mfaEnabled     Boolean         @default(false)
  accessScope    String?         // "Full network" / "Backup subnet only"
  certExpiry     DateTime?
  isActive       Boolean         @default(true)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  gateway        VpnGateway      @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  clientUser     ClientUser?     @relation("ClientUserVpnAccess", fields: [clientUserId], references: [id])
  vendor         Vendor?         @relation("VendorVpnAccess", fields: [vendorId], references: [id])
  staffUser      StaffUser?      @relation("StaffUserVpnAccess", fields: [staffUserId], references: [id])
  contact        Contact?        @relation("ContactVpnAccess", fields: [contactId], references: [id])
  credential     Credential?     @relation("CredentialVpnAccessor", fields: [credentialId], references: [id])
}

enum VpnType {
  OPENVPN
  SONICWALL_GVN
  MERAKI_VPN
  TAILSCALE
  L2TP_IPSEC
  WIREGUARD
  CISCO_ANYCONNECT
  FORTINET
  OTHER
}

enum VpnAccessorType {
  CLIENT_USER
  VENDOR
  STAFF_USER
  CONTACT
  THIRD_PARTY
}

// ─── Phone Systems ────────────────────────────────────────────────────────────

model PhoneSystem {
  id            String           @id @default(cuid())
  clientId      String
  assetId       String?          // UCM/PBX box as asset
  credentialId  String?          // admin credential in vault
  name          String           // e.g. "Grandstream UCM6304"
  type          PhoneSystemType
  sipDomain     String?          // SIP realm / domain
  managementUrl String?
  notes         String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  asset         Asset?           @relation("AssetPhoneSystem", fields: [assetId], references: [id])
  credential    Credential?      @relation("CredentialPhoneSystem", fields: [credentialId], references: [id])
  extensions    PhoneExtension[]
}

model PhoneExtension {
  id               String              @id @default(cuid())
  systemId         String
  clientUserId     String?             // linked client user
  assetId          String?             // handset asset
  credentialId     String?             // SIP credential in vault
  voicemailCredId  String?             // voicemail PIN credential in vault
  extension        String              // e.g. "101"
  displayName      String              // e.g. "Jane Smith" or "Reception"
  type             PhoneExtensionType  @default(USER)
  did              String?             // direct inward dial number
  voicemailEnabled Boolean             @default(false)
  notes            String?
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  system           PhoneSystem         @relation(fields: [systemId], references: [id], onDelete: Cascade)
  clientUser       ClientUser?         @relation("ClientUserExtension", fields: [clientUserId], references: [id])
  asset            Asset?              @relation("AssetPhoneExtension", fields: [assetId], references: [id])
  credential       Credential?         @relation("CredentialPhoneExtension", fields: [credentialId], references: [id])
  voicemailCred    Credential?         @relation("CredentialVoicemail", fields: [voicemailCredId], references: [id])
}

enum PhoneSystemType {
  GRANDSTREAM_UCM
  FREEPBX
  THREE_CX
  HOSTED_VOIP
  MITEL
  AVAYA
  CISCO
  OTHER
}

enum PhoneExtensionType {
  USER
  RING_GROUP
  IVR
  VOICEMAIL_ONLY
  FAX
  PAGING
  CONFERENCE
}

// ─── Camera Systems ───────────────────────────────────────────────────────────

model CameraSystem {
  id            String           @id @default(cuid())
  clientId      String
  assetId       String?          // NVR/DVR as asset
  credentialId  String?          // admin credential in vault
  name          String           // e.g. "Unifi Protect NVR", "Front Office DVR"
  type          CameraSystemType
  managementUrl String?
  retentionDays Int?
  storageNote   String?          // e.g. "2TB HDD, ~30 days at 1080p"
  notes         String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  asset         Asset?           @relation("AssetCameraSystem", fields: [assetId], references: [id])
  credential    Credential?      @relation("CredentialCameraSystem", fields: [credentialId], references: [id])
  cameras       Camera[]
}

model Camera {
  id          String       @id @default(cuid())
  systemId    String
  assetId     String?      // Unifi camera linked as an asset
  name        String       // e.g. "Front Door", "Parking Lot NE"
  type        CameraType   @default(IP_POE)
  make        String?
  model       String?
  ipAddress   String?
  macAddress  String?
  resolution  String?      // e.g. "4MP", "1080p"
  location    String?      // physical description
  notes       String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  system      CameraSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
  asset       Asset?       @relation("AssetCamera", fields: [assetId], references: [id])
}

enum CameraSystemType {
  UNIFI_NVR
  HIKVISION_DVR
  DAHUA_DVR
  ANALOG_DVR
  CLOUD_MANAGED
  OTHER
}

enum CameraType {
  IP_POE
  ANALOG
  WIRELESS
  FISHEYE
  PTZ
}

// ─── Wireless ─────────────────────────────────────────────────────────────────

model WifiController {
  id              String            @id @default(cuid())
  clientId        String
  assetId         String?           // on-prem controller hardware as asset
  networkDeviceId String?           // controller as a network device record
  credentialId    String?           // admin credential in vault
  name            String            // e.g. "Unifi Controller", "Meraki Dashboard"
  type            WifiControllerType
  managementUrl   String?
  notes           String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  asset           Asset?            @relation("AssetWifiController", fields: [assetId], references: [id])
  networkDevice   NetworkDevice?    @relation("NetworkDeviceWifiController", fields: [networkDeviceId], references: [id])
  credential      Credential?       @relation("CredentialWifiController", fields: [credentialId], references: [id])
  networks        WifiNetwork[]
}

model WifiNetwork {
  id              String          @id @default(cuid())
  controllerId    String
  credentialId    String?         // PSK credential in vault
  subnetId        String?         // optional link to IPAM subnet
  ssid            String
  band            WifiBand        @default(DUAL)
  security        WifiSecurity    @default(WPA2_PERSONAL)
  purpose         WifiPurpose     @default(CORPORATE)
  vlanId          Int?            // VLAN tag (fallback if no subnet linked)
  vlanName        String?         // e.g. "Corp", "Guest", "IoT"
  isHidden        Boolean         @default(false)
  clientIsolation Boolean         @default(false)
  bandSteering    Boolean         @default(false)
  isActive        Boolean         @default(true)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  controller      WifiController  @relation(fields: [controllerId], references: [id], onDelete: Cascade)
  credential      Credential?     @relation("CredentialWifiNetwork", fields: [credentialId], references: [id])
  subnet          Subnet?         @relation(fields: [subnetId], references: [id])
}

enum WifiControllerType {
  UNIFI
  MERAKI
  HP_INSTANT_ON
  GRANDSTREAM
  UBIQUITI_CLOUD
  STANDALONE
  OTHER
}

enum WifiBand {
  DUAL
  TRI
  TWO_FOUR
  FIVE
  SIX
}

enum WifiSecurity {
  WPA2_PERSONAL
  WPA2_ENTERPRISE
  WPA3_PERSONAL
  WPA3_ENTERPRISE
  WPA2_WPA3_TRANSITION
  OPEN
}

enum WifiPurpose {
  CORPORATE
  GUEST
  IOT
  VOIP
  CAMERAS
  MANAGEMENT
  OTHER
}
