generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StaffUser {
  id                  String                @id @default(cuid())
  email               String                @unique
  name                String?
  role                UserRole              @default(TECH)
  isActive            Boolean               @default(true)
  microsoftId         String?               @unique
  passkeyChallenge    String? // ephemeral, cleared after each WebAuthn ceremony
  /// Per-user IP allowlist. Array of CIDR strings (e.g., ["100.64.0.0/10",
  /// "203.0.113.5/32"]). Empty = no per-user restriction. Only enforced
  /// when the global AppSetting `security:staff_ip_allowlist_enabled` is
  /// "true". Tailscale CGNAT range (100.64.0.0/10) is always implicitly
  /// allowed so a lockout via misconfig is recoverable.
  ipAllowlist         String[]              @default([])
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  activityEvents      ActivityEvent[]
  vpnAccess           VpnAccessor[]         @relation("StaffUserVpnAccess")
  apiKeys             ApiKey[]
  personalCredentials PersonalCredential[]
  personalSecureNotes PersonalSecureNote[]
  passkeys            StaffUserPasskey[]
  vaultSession        PersonalVaultSession?
}

model PersonalCredential {
  id                String    @id @default(cuid())
  staffUserId       String
  label             String
  username          String?
  encryptedPassword String
  encryptedTotp     String?
  encryptedNotes    String?
  url               String?
  /// DEPRECATED — moved to encryptedNotes (encrypted at rest). Read path
  /// falls back to this if encryptedNotes is null. Phase 2 drops this col.
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  staffUser         StaffUser @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
}

model PersonalSecureNote {
  id             String                @id @default(cuid())
  staffUserId    String
  title          String
  category       PersonalNoteCategory  @default(GENERIC)
  encryptedBody  String
  tags           String[]              @default([])
  isFavorite     Boolean               @default(false)
  expiryDate     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  staffUser      StaffUser             @relation(fields: [staffUserId], references: [id], onDelete: Cascade)

  @@index([staffUserId, updatedAt])
  @@index([staffUserId, category])
  @@index([expiryDate])
}

enum PersonalNoteCategory {
  LICENSE_KEY
  RECOVERY_CODES
  BIOS_FIRMWARE
  API_TOKEN
  SOFTWARE_LICENSE
  SSH_KEY
  PROCEDURE
  GENERIC
}

model StaffUserPasskey {
  id           String    @id @default(cuid())
  staffUserId  String
  name         String
  credentialId Bytes
  publicKey    Bytes
  counter      BigInt    @default(0)
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  staffUser    StaffUser @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
}

model PersonalVaultSession {
  id          String    @id @default(cuid())
  staffUserId String    @unique
  expiresAt   DateTime
  staffUser   StaffUser @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  staffUserId String
  expiresAt   DateTime? // null = never expires (legacy keys)
  scope       String? // null = full; "read" = no credential reveal
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  staffUser   StaffUser @relation(fields: [staffUserId], references: [id])
}

model Client {
  id                String             @id @default(cuid())
  name              String
  type              ClientType         @default(BUSINESS)
  syncroId          String?            @unique
  notes             String?
  isActive          Boolean            @default(true)
  lastSyncedAt      DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  activityEvents    ActivityEvent[]
  alarms            Alarm[]
  applications      Application[]
  attachments       ClientAttachment[]
  documents         ClientDocument[]
  documentFolders   DocumentFolder[]
  people            Person[]
  credentials       Credential[]
  licenses          License[]
  locations         Location[]
  networkDevices    NetworkDevice[]
  runbooks          Runbook[]
  runbookRuns       RunbookRun[]
  subnets           Subnet[]
  vlans             Vlan[]
  websites          Website[]
  vendors           Vendor[]           @relation("ClientVendors")
  vendorContracts   VendorContract[]   @relation("ClientContracts")
  vendorGrants      VendorClientGrant[]

  /// Optional Runbook templates fired automatically on lifecycle events.
  /// Onboarding runs when a Person.isActive flips to true; offboarding
  /// when it flips false; newClient on initial Client.create. Pick the
  /// templates per client via Settings → Lifecycle on the client page.
  onboardingRunbookId   String?
  onboardingRunbook     Runbook? @relation("ClientOnboardingRunbook",  fields: [onboardingRunbookId],  references: [id])
  offboardingRunbookId  String?
  offboardingRunbook    Runbook? @relation("ClientOffboardingRunbook", fields: [offboardingRunbookId], references: [id])
  newClientRunbookId    String?
  newClientRunbook      Runbook? @relation("ClientNewClientRunbook",   fields: [newClientRunbookId],   references: [id])
  adDomains         AdDomain[]
  networkShares     NetworkShare[]
  vpnGateways       VpnGateway[]
  phoneSystems      PhoneSystem[]
  cameraSystems     CameraSystem[]
  wifiControllers   WifiController[]
  ptpLinks          PtpLink[]
  portalUsers       PortalUser[]
  portalCredentials PortalCredential[]
  networkDiagram    NetworkDiagram?
  backupConfigs     BackupConfig[]
  intakeSuggestions IntakeSuggestion[]
  internetCircuits  InternetCircuit[]
}

model Location {
  id             String          @id @default(cuid())
  clientId       String
  name           String
  address        String?
  city           String?
  state          String?
  zip            String?
  ispName        String?
  wanIp          String?
  tailscaleIp    String? // Tailscale IP for on-site UCG/controller — enables live port, DHCP, VLAN, WiFi sync
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assets         Asset[]
  client         Client          @relation(fields: [clientId], references: [id])
  networkDevices NetworkDevice[]
  racks          Rack[]
  subnets        Subnet[]
  ptpSideA       PtpLink[]       @relation("PtpSideA")
  ptpSideB       PtpLink[]       @relation("PtpSideB")
  attachments    ClientAttachment[] @relation("LocationAttachments")
  internetCircuits InternetCircuit[]
  /// Cross-app pointer to TicketHub's TH_Site.id. Populated lazily on
  /// first successful name-match resolve so subsequent cross-schema
  /// lookups are O(1). Null = no matching TH_Site yet (DocHub has 178
  /// locations vs ~61 TH sites today, so most rows stay null).
  thSiteId       String?         @unique
}

model Person {
  id              String              @id @default(cuid())
  clientId        String
  name            String
  email           String?
  phone           String?
  mobile          String?
  m365Upn         String?
  jobTitle        String?
  role            String?
  isPrimary       Boolean             @default(false)
  isBilling       Boolean             @default(false)
  isEscalation    Boolean             @default(false)
  isActive        Boolean             @default(true)
  notes           String?
  syncroContactId String?             @unique
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  client          Client              @relation(fields: [clientId], references: [id])
  applications    Application[]       @relation("ApplicationPerson")
  assets          Asset[]             @relation("AssetPerson")
  credentials     Credential[]        @relation("CredentialPerson")
  ipAssignments   IpAssignment[]      @relation("PersonIpAssignment")
  licenses        License[]           @relation("LicensePerson")
  vpnAccess       VpnAccessor[]       @relation("PersonVpnAccess")
  phoneExtensions PhoneExtension[]    @relation("PersonExtension")
  appSeats        AppSeatAssignment[] @relation("AppSeatPerson")
  licenseSeats    LicenseSeatAssignment[] @relation("LicenseSeatPerson")
  portalUsers     PortalUser[]        @relation("PortalUserPerson")
}



model AssetType {
  id          String             @id @default(cuid())
  name        String
  description String?
  isActive    Boolean            @default(true)
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  assets      Asset[]
  template    AssetTypeTemplate?
}

model AssetTypeTemplate {
  id              String    @id @default(cuid())
  assetTypeId     String    @unique
  standardFields  String[] // ordered list of standard field keys to surface in forms/cards
  customFieldDefs Json      @default("[]") // [{ key, label, type, required }]
  showSwitchPanel Boolean   @default(false)
  showCameraPhoto Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  assetType       AssetType @relation(fields: [assetTypeId], references: [id], onDelete: Cascade)
}

model Asset {
  id                 String                 @id @default(cuid())
  locationId         String
  personId           String?
  category           AssetCategory          @default(OTHER)
  status             AssetStatus            @default(ACTIVE)
  name               String
  make               String?
  model              String?
  serial             String?
  assetTag           String?
  ipAddress          String?
  macAddress         String?
  vlan               String?
  switchPort         String?
  managementUrl      String?
  purchaseDate       DateTime?
  warrantyExpiry     DateTime?
  room               String?
  syncroAssetId      String?                @unique
  notes              String?
  successorId        String?                @unique
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  splashtopUrl       String?
  driverUrl          String?
  friendlyName       String?
  isFavorite         Boolean                @default(false)
  rdpEnabled         Boolean                @default(false)
  rdpHost            String?
  rdpPort            Int?
  vncEnabled         Boolean                @default(false)
  vncHost            String?
  vncPort            Int?
  assetTypeId        String?
  purchaseVendorId   String?
  dataSource         String                 @default("MANUAL")
  // Typed extended fields (surfaced based on AssetTypeTemplate.standardFields)
  firmwareVersion    String?
  portCount          Int?
  os                 String? // e.g. "Windows 11 Pro", "Ubuntu 22.04"
  ram                String? // e.g. "16GB", "32GB DDR5"
  cpu                String? // e.g. "Intel i7-13700", "AMD Ryzen 9"
  storageCapacity    String? // e.g. "1TB NVMe SSD", "2x4TB RAID1"
  customFields       Json? // { [key: string]: string } from template custom field defs
  assetType          AssetType?             @relation(fields: [assetTypeId], references: [id])
  location           Location               @relation(fields: [locationId], references: [id])
  person             Person?                @relation("AssetPerson", fields: [personId], references: [id])
  successor          Asset?                 @relation("AssetSuccessor", fields: [successorId], references: [id])
  predecessor        Asset?                 @relation("AssetSuccessor")
  credentials        Credential[]
  exitInterview      ExitInterview?
  ipAssignments      IpAssignment[]         @relation("AssetIpAssignment")
  rackSlots          RackSlot[]             @relation("AssetRackSlot")
  networkShares      NetworkShare[]         @relation("AssetNetworkShare")
  interfaces         AssetInterface[]
  switchPorts        SwitchPort[]
  vpnGateways        VpnGateway[]           @relation("AssetVpnGateway")
  phoneSystems       PhoneSystem[]          @relation("AssetPhoneSystem")
  phoneExtensions    PhoneExtension[]       @relation("AssetPhoneExtension")
  cameraSystems      CameraSystem[]         @relation("AssetCameraSystem")
  cameras            Camera[]               @relation("AssetCamera")
  wifiControllers    WifiController[]       @relation("AssetWifiController")
  networkDevice      NetworkDevice? // if migrated from NetworkDevice
  synologyConfig     SynologyConfig?
  backupProtections  BackupProtectedAsset[]
  assetLinksFrom     AssetLink[]            @relation("AssetLinksFrom")
  assetLinksTo       AssetLink[]            @relation("AssetLinksTo")
  linkedLicenses     License[]              @relation("LicenseAsset")
  linkedApplications Application[]          @relation("ApplicationAsset")
  linkedDocuments    ClientDocument[]       @relation("DocumentAsset")
  linkedRunbooks     Runbook[]              @relation("RunbookAsset")
  linkedWebsites     Website[]              @relation("WebsiteAsset")
  ptpLinksSideA      PtpLink[]              @relation("PtpLinkSideA")
  ptpLinksSideB      PtpLink[]              @relation("PtpLinkSideB")
  linkedAlarms       Alarm[]                @relation("AlarmAsset")
  attachments        ClientAttachment[]     @relation("AssetAttachments")
  circuitsAsModem    InternetCircuit[]      @relation("CircuitModemAsset")
  circuitsAsEdge     InternetCircuit[]      @relation("CircuitEdgeAsset")
  purchaseVendor     Vendor?                @relation("AssetPurchaseVendor", fields: [purchaseVendorId], references: [id])
  licenseSeats       LicenseSeatAssignment[] @relation("LicenseSeatAsset")
}

model SynologyConfig {
  id                String              @id @default(cuid())
  assetId           String              @unique
  port              Int                 @default(5001)
  useHttps          Boolean             @default(true)
  skipSslVerify     Boolean             @default(true)
  username          String
  encryptedPassword String
  lastSyncedAt      DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  asset             Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  backupJobs        SynologyBackupJob[]
}

model SynologyBackupJob {
  id          String         @id @default(cuid())
  configId    String
  taskId      String
  name        String
  type        String // "hyper_backup" | "active_backup"
  lastResult  String? // "success" | "error" | "warning" | "running" | "unfinished" | "none"
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  destination String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  config      SynologyConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, taskId])
}

// ─── Backup Documentation ─────────────────────────────────────────────────────

model BackupConfig {
  id                String                 @id @default(cuid())
  clientId          String
  name              String // e.g. "All Servers — Veeam", "Workstations — Datto"
  technology        String // e.g. "Veeam", "Datto SIRIS", "Acronis", "Windows Server Backup", "Synology Active Backup"
  type              String                 @default("image") // "image" | "file" | "cloud" | "hybrid"
  frequency         String? // e.g. "Every 4 hours", "Nightly", "Hourly"
  window            String? // e.g. "10PM-6AM", "Continuous"
  retentionPolicy   String? // e.g. "30 days local, 90 days cloud"
  target            String? // e.g. "Local NAS + Wasabi S3", "Datto Cloud"
  encryptionEnabled Boolean                @default(false)
  lastVerifiedAt    DateTime? // last test restore or verification
  nextVerifyBy      DateTime? // when next verification is due (triggers alarm)
  verifiedBy        String? // who last verified
  status            String                 @default("active") // "active" | "paused" | "retired"
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  client            Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  protectedAssets   BackupProtectedAsset[]
}

model BackupProtectedAsset {
  id             String       @id @default(cuid())
  backupConfigId String
  assetId        String? // linked DocHub asset (optional)
  hostname       String? // if no asset link, manual hostname
  type           String       @default("server") // "server" | "workstation" | "nas" | "vm" | "cloud" | "other"
  notes          String?
  backupConfig   BackupConfig @relation(fields: [backupConfigId], references: [id], onDelete: Cascade)
  asset          Asset?       @relation(fields: [assetId], references: [id])

  @@unique([backupConfigId, assetId])
}

model AssetLink {
  id            String   @id @default(cuid())
  assetId       String
  linkedAssetId String
  relationType  String // e.g. "POWERS", "RECORDS_TO", "CONNECTS_TO", "HOSTS", "MONITORS", "BACKS_UP", "REPLACED_BY", "RELATED"
  notes         String?
  createdAt     DateTime @default(now())
  asset         Asset    @relation("AssetLinksFrom", fields: [assetId], references: [id], onDelete: Cascade)
  linkedAsset   Asset    @relation("AssetLinksTo", fields: [linkedAssetId], references: [id], onDelete: Cascade)

  @@unique([assetId, linkedAssetId, relationType])
}

model ExitInterview {
  id        String   @id @default(cuid())
  assetId   String   @unique
  reason    String
  retiredBy String
  retiredAt DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id])
}

model Credential {
  id                  String           @id @default(cuid())
  clientId            String
  assetId             String?
  label               String
  username            String?
  encryptedPassword   String
  encryptedTotp       String?
  encryptedNotes      String?
  url                 String?
  notes               String?
  isRetired           Boolean          @default(false)
  isFavorite          Boolean          @default(false)
  lastRotated         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  personId            String?
  expiryDate          DateTime?
  dataSource          String           @default("MANUAL")
  /// RBAC escape hatch: when true, TECH-role users can reveal this
  /// credential's password/TOTP/notes. Default false — only ADMIN sees
  /// values. Set per-credential when the whole team shares the login.
  allowTechReveal     Boolean          @default(false)
  asset               Asset?           @relation(fields: [assetId], references: [id])
  client              Client           @relation(fields: [clientId], references: [id])
  person              Person?          @relation("CredentialPerson", fields: [personId], references: [id])
  vpnGateways         VpnGateway[]     @relation("CredentialVpnGateway")
  vpnAccessors        VpnAccessor[]    @relation("CredentialVpnAccessor")
  phoneSystems        PhoneSystem[]    @relation("CredentialPhoneSystem")
  phoneExtensions     PhoneExtension[] @relation("CredentialPhoneExtension")
  voicemailExtensions PhoneExtension[] @relation("CredentialVoicemail")
  cameraSystems       CameraSystem[]   @relation("CredentialCameraSystem")
  wifiControllers     WifiController[] @relation("CredentialWifiController")
  wifiNetworks        WifiNetwork[]    @relation("CredentialWifiNetwork")
  ptpLinks            PtpLink[]        @relation("CredentialPtpLink")
  adDomains           AdDomain[]       @relation("CredentialAdDomain")
  assetInterfaces     AssetInterface[]
  internetCircuits    InternetCircuit[] @relation("CredentialInternetCircuit")
  websites            Website[]        @relation("CredentialWebsite")
}

model License {
  id             String      @id @default(cuid())
  clientId       String
  name           String
  vendor         String?
  seats          Int?
  expiryDate     DateTime?
  renewalDate    DateTime?
  cost           Float?
  pax8Id         String?
  notes          String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  personId       String?
  assignedSeats  Int?
  licenseKey     String?
  purchaseDate   DateTime?
  vendorId       String?
  dataSource     String      @default("MANUAL")
  billingTerm    String?
  status         String?
  assetId        String?
  asset          Asset?      @relation("LicenseAsset", fields: [assetId], references: [id])
  client         Client      @relation(fields: [clientId], references: [id])
  person         Person?     @relation("LicensePerson", fields: [personId], references: [id])
  vendorRef      Vendor?     @relation(fields: [vendorId], references: [id])
  seatAssignments LicenseSeatAssignment[]
}

// Per-seat assignment for a License — who/what consumes a seat. Mirrors
// AppSeatAssignment so assignedSeats can be DERIVED (count) instead of a
// hand-typed integer that drifts. personId XOR assetId (a seat goes to a
// person or a device); both nullable for a placeholder seat.
model LicenseSeatAssignment {
  id        String   @id @default(cuid())
  licenseId String
  personId  String?
  assetId   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  license   License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  person    Person?  @relation("LicenseSeatPerson", fields: [personId], references: [id])
  asset     Asset?   @relation("LicenseSeatAsset", fields: [assetId], references: [id])
}

model Application {
  id              String              @id @default(cuid())
  clientId        String
  name            String
  vendor          String?
  version         String?
  supportUrl      String?
  notes           String?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  personId        String?
  vendorId        String?
  // LOB fields
  isLob           Boolean             @default(false)
  accessType      String? // "rdp" | "url" | null
  rdpHost         String? // RDP server hostname/IP
  rdpPort         Int? // RDP port (default 3389)
  rdpGateway      String? // RD Gateway (optional)
  appUrl          String? // Web application URL
  totalSeats      Int? // licensed seat count
  assetId         String?
  asset           Asset?              @relation("ApplicationAsset", fields: [assetId], references: [id])
  client          Client              @relation(fields: [clientId], references: [id])
  person          Person?             @relation("ApplicationPerson", fields: [personId], references: [id])
  vendorRef       Vendor?             @relation(fields: [vendorId], references: [id])
  seatAssignments AppSeatAssignment[]
}

model AppSeatAssignment {
  id                 String      @id @default(cuid())
  applicationId      String
  personId           String?
  seatUsername       String? // the app-specific username (e.g. "user01")
  seatPassword       String? // encrypted app-specific password
  portalCredentialId String? // auto-created portal vault entry
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  application        Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  person             Person?     @relation("AppSeatPerson", fields: [personId], references: [id])

  @@unique([applicationId, seatUsername])
}

// Contact model removed — merged into Person

model Alarm {
  id              String        @id @default(cuid())
  clientId        String
  severity        AlarmSeverity @default(INFO)
  status          AlarmStatus   @default(ACTIVE)
  type            String
  message         String
  details         String?
  visibleToClient Boolean       @default(false)
  dismissedAt     DateTime?
  resolvedAt      DateTime?
  assetId         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  asset           Asset?        @relation("AlarmAsset", fields: [assetId], references: [id])
  client          Client        @relation(fields: [clientId], references: [id])
}

model ActivityEvent {
  id              String            @id @default(cuid())
  clientId        String
  staffUserId     String?
  eventType       ActivityEventType
  title           String
  body            String?
  isPinned        Boolean           @default(false)
  visibleToClient Boolean           @default(false)
  dismissedAt     DateTime?
  createdAt       DateTime          @default(now())
  client          Client            @relation(fields: [clientId], references: [id])
  staffUser       StaffUser?        @relation(fields: [staffUserId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  ext_expires_in    Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vendor {
  id            String          @id @default(cuid())
  name          String
  website       String?
  supportUrl    String?
  supportPhone  String?
  supportEmail  String?
  accountNumber String?
  notes         String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  category      VendorCategory  @default(OTHER)
  portalUrl     String?
  applications  Application[]
  licenses      License[]
  contacts      VendorContact[]
  contracts     VendorContract[]
  clients       Client[]        @relation("ClientVendors")
  vpnAccess     VpnAccessor[]   @relation("VendorVpnAccess")
  sipTrunks     SipTrunk[]      @relation("VendorSipTrunks")
  potsLines     PotsLine[]      @relation("VendorPotsLines")
  attachments   ClientAttachment[] @relation("VendorAttachments")
  internetCircuits InternetCircuit[] @relation("VendorInternetCircuits")
  websitesAsRegistrar Website[]   @relation("WebsiteRegistrar")
  purchasedAssets Asset[]         @relation("AssetPurchaseVendor")
  portalGrants  VendorClientGrant[]
}

/// A vendor-portal access grant: one client's vendor (e.g. "American
/// Choice" serving "Braddock Medical") may sign in to the vendor portal
/// and see ONLY the specific credentials/documents shared with them here.
/// Default-deny — nothing is visible until a VendorShare row is added.
/// Managed by internal staff (v1). One grant per (client, vendor) pair.
model VendorClientGrant {
  id               String        @id @default(cuid())
  clientId         String
  vendorId         String
  /// Human label for the access package, e.g. "VPN + RDP access".
  label            String?
  isActive         Boolean       @default(true)
  createdByStaffId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  client           Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vendor           Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  shares           VendorShare[]

  @@unique([clientId, vendorId])
  @@index([vendorId])
}

enum VendorShareType {
  CREDENTIAL
  DOCUMENT
  ATTACHMENT
  /// A customer-portal vault credential (PortalCredential) the CLIENT chose
  /// to share with their vendor (phase 2, client-self-managed). Distinct from
  /// CREDENTIAL, which is an MSP-held internal Credential shared by staff and
  /// is never visible to / manageable by the client.
  PORTAL_CREDENTIAL
}

/// One explicitly shared item inside a VendorClientGrant. The presence of
/// a row is the entire authorization — the vendor BFF only ever returns
/// items that have a matching VendorShare. itemId points at a Credential,
/// ClientDocument, ClientAttachment, or PortalCredential depending on itemType.
model VendorShare {
  id               String            @id @default(cuid())
  grantId          String
  itemType         VendorShareType
  itemId           String
  note             String?
  /// Staff email when an MSP admin created the share (v1 path).
  createdByStaffId String?
  /// portal.portal_users.id when a CLIENT portal user self-managed the share
  /// (phase 2). Exactly one of createdByStaffId / createdByPortalUserId is set;
  /// the client surface only ever lists/mutates rows of manageable item types.
  createdByPortalUserId String?
  createdAt        DateTime          @default(now())
  grant            VendorClientGrant @relation(fields: [grantId], references: [id], onDelete: Cascade)

  @@unique([grantId, itemType, itemId])
  @@index([grantId])
}

/// One row per integration cron — written on every run so Settings can
/// surface "last ran X ago, OK" or the most recent error message.
model IntegrationSyncStatus {
  key       String   @id
  status    String   // OK | ERROR | DEGRADED | UNCONFIGURED
  lastRunAt DateTime
  message   String?
  detail    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Vendor contracts (MSAs, SLAs, leases, subscriptions). Distinct from
/// software licenses (License model) — those track per-seat product
/// licensing; this tracks the umbrella vendor agreement.
model VendorContract {
  id           String    @id @default(cuid())
  vendorId     String
  vendor       Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  /// Optional client scope — when set, the contract applies to that
  /// client only (rather than vendor-wide). Useful for client-specific
  /// MSAs that go through a shared vendor.
  clientId     String?
  client       Client?   @relation("ClientContracts", fields: [clientId], references: [id])
  name         String
  contractType String?   // MSA / SLA / LEASE / SUBSCRIPTION / NDA / OTHER
  startDate    DateTime?
  endDate      DateTime?
  autoRenew    Boolean   @default(false)
  renewalDate  DateTime?
  /// Total contract value in cents (one-time) or per costPeriod amount.
  cost         Int?
  costPeriod   String?   // ANNUAL / MONTHLY / ONE_TIME
  documentUrl  String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  attachments  ClientAttachment[] @relation("VendorContractAttachments")

  @@index([vendorId])
  @@index([clientId])
  @@index([endDate])
  @@index([renewalDate])
}

