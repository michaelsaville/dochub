  isActive       Boolean         @default(true)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  gateway        VpnGateway      @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  person         Person?         @relation("PersonVpnAccess", fields: [personId], references: [id])
  vendor         Vendor?         @relation("VendorVpnAccess", fields: [vendorId], references: [id])
  staffUser      StaffUser?      @relation("StaffUserVpnAccess", fields: [staffUserId], references: [id])
  credential     Credential?     @relation("CredentialVpnAccessor", fields: [credentialId], references: [id])
}

enum VpnType {
  OPENVPN
  SONICWALL_GVN
  MERAKI_VPN
  TAILSCALE
  L2TP_IPSEC
  WIREGUARD
  CISCO_ANYCONNECT
  FORTINET
  OTHER
}

enum VpnAccessorType {
  PERSON
  VENDOR
  STAFF_USER
  THIRD_PARTY
  CLIENT_USER  // @deprecated — migrated to PERSON, kept for enum compat
  CONTACT      // @deprecated — migrated to PERSON, kept for enum compat
}

// ─── Phone Systems ────────────────────────────────────────────────────────────

model PhoneSystem {
  id            String           @id @default(cuid())
  clientId      String
  assetId       String? // UCM/PBX box as asset
  credentialId  String? // admin credential in vault
  name          String // e.g. "Grandstream UCM6304"
  type          PhoneSystemType
  sipDomain     String? // SIP realm / domain
  managementUrl String?
  notes         String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  asset         Asset?           @relation("AssetPhoneSystem", fields: [assetId], references: [id])
  credential    Credential?      @relation("CredentialPhoneSystem", fields: [credentialId], references: [id])
  extensions    PhoneExtension[]
  sipTrunks     SipTrunk[]
  potsLines     PotsLine[]
}

model SipTrunk {
  id            String      @id @default(cuid())
  systemId      String
  vendorId      String? // FK to Vendor (preferred)
  carrier       String // fallback name if vendor not in system
  accountNumber String?
  supportPhone  String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  system        PhoneSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
  vendor        Vendor?     @relation("VendorSipTrunks", fields: [vendorId], references: [id])
  dids          SipDid[]
}

model SipDid {
  id          String          @id @default(cuid())
  trunkId     String
  number      String // e.g. "+13045550100"
  designation String? // e.g. "Line 1", "Main", "Fax", "Toll-Free"
  extensionId String? // optionally routed to an extension
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  trunk       SipTrunk        @relation(fields: [trunkId], references: [id], onDelete: Cascade)
  extension   PhoneExtension? @relation("ExtensionSipDid", fields: [extensionId], references: [id])
}

model PotsLine {
  id            String       @id @default(cuid())
  systemId      String
  vendorId      String? // FK to Vendor (preferred)
  carrier       String // fallback carrier name e.g. "AT&T", "Lumen"
  accountNumber String?
  supportPhone  String?
  circuitId     String? // billing / circuit ID from the carrier
  notes         String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  system        PhoneSystem  @relation(fields: [systemId], references: [id], onDelete: Cascade)
  vendor        Vendor?      @relation("VendorPotsLines", fields: [vendorId], references: [id])
  numbers       PotsNumber[]
}

model PotsNumber {
  id          String          @id @default(cuid())
  lineId      String
  number      String // e.g. "+13045550105"
  designation String? // e.g. "Line 1", "Line 2", "Fax"
  port        String? // physical port label e.g. "FXO 1", "Port 2"
  extensionId String? // optionally routed to an extension
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  line        PotsLine        @relation(fields: [lineId], references: [id], onDelete: Cascade)
  extension   PhoneExtension? @relation("ExtensionPotsNumber", fields: [extensionId], references: [id])
}

model PhoneExtension {
  id               String             @id @default(cuid())
  systemId         String
  personId         String?
  assetId          String? // handset asset
  credentialId     String? // SIP credential in vault
  voicemailCredId  String? // voicemail PIN credential in vault
  extension        String // e.g. "101"
  displayName      String // e.g. "Jane Smith" or "Reception"
  type             PhoneExtensionType @default(USER)
  did              String? // direct inward dial number
  voicemailEnabled Boolean            @default(false)
  notes            String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  system           PhoneSystem        @relation(fields: [systemId], references: [id], onDelete: Cascade)
  person           Person?            @relation("PersonExtension", fields: [personId], references: [id])
  asset            Asset?             @relation("AssetPhoneExtension", fields: [assetId], references: [id])
  credential       Credential?        @relation("CredentialPhoneExtension", fields: [credentialId], references: [id])
  voicemailCred    Credential?        @relation("CredentialVoicemail", fields: [voicemailCredId], references: [id])
  sipDids          SipDid[]           @relation("ExtensionSipDid")
  potsNumbers      PotsNumber[]       @relation("ExtensionPotsNumber")
}

enum PhoneSystemType {
  GRANDSTREAM_UCM
  FREEPBX
  THREE_CX
  HOSTED_VOIP
  MITEL
  AVAYA
  CISCO
  OTHER
}

enum PhoneExtensionType {
  USER
  RING_GROUP
  IVR
  VOICEMAIL_ONLY
  FAX
  PAGING
  CONFERENCE
}

// ─── Camera Systems ───────────────────────────────────────────────────────────

model CameraSystem {
  id            String           @id @default(cuid())
  clientId      String
  assetId       String? // NVR/DVR as asset
  credentialId  String? // admin credential in vault
  name          String // e.g. "Unifi Protect NVR", "Front Office DVR"
  type          CameraSystemType
  managementUrl String?
  retentionDays Int?
  storageNote   String? // e.g. "2TB HDD, ~30 days at 1080p"
  notes         String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  asset         Asset?           @relation("AssetCameraSystem", fields: [assetId], references: [id])
  credential    Credential?      @relation("CredentialCameraSystem", fields: [credentialId], references: [id])
  cameras       Camera[]
}

model Camera {
  id                String       @id @default(cuid())
  systemId          String
  assetId           String? // Unifi camera linked as an asset
  name              String // e.g. "Front Door", "Parking Lot NE"
  type              CameraType   @default(IP_POE)
  make              String?
  model             String?
  ipAddress         String?
  macAddress        String?
  resolution        String? // e.g. "4MP", "1080p"
  location          String? // physical description
  recordingSchedule String? // "24_7", "MOTION", "SCHEDULE", "NONE"
  coverageNotes     String? // description of what the camera covers
  photoStorageName  String? // field-of-view reference photo
  unifiCameraId     String? // UniFi Protect camera ID for API snapshot sync
  photoRefreshedAt  DateTime? // last time thumbnail was auto-synced from NVR
  notes             String?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  system            CameraSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
  asset             Asset?       @relation("AssetCamera", fields: [assetId], references: [id])
}

enum CameraSystemType {
  UNIFI_NVR
  HIKVISION_DVR
  DAHUA_DVR
  ANALOG_DVR
  CLOUD_MANAGED
  OTHER
}

enum CameraType {
  IP_POE
  ANALOG
  WIRELESS
  FISHEYE
  PTZ
}

// ─── Wireless ─────────────────────────────────────────────────────────────────

model WifiController {
  id              String             @id @default(cuid())
  clientId        String
  assetId         String? // on-prem controller hardware as asset
  networkDeviceId String? // controller as a network device record
  credentialId    String? // admin credential in vault
  name            String // e.g. "Unifi Controller", "Meraki Dashboard"
  type            WifiControllerType
  managementUrl   String?
  notes           String?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  client          Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  asset           Asset?             @relation("AssetWifiController", fields: [assetId], references: [id])
  networkDevice   NetworkDevice?     @relation("NetworkDeviceWifiController", fields: [networkDeviceId], references: [id])
  credential      Credential?        @relation("CredentialWifiController", fields: [credentialId], references: [id])
  networks        WifiNetwork[]
}

model WifiNetwork {
  id              String         @id @default(cuid())
  controllerId    String
  credentialId    String? // PSK credential in vault
  subnetId        String? // optional link to IPAM subnet
  ssid            String
  band            WifiBand       @default(DUAL)
  security        WifiSecurity   @default(WPA2_PERSONAL)
  purpose         WifiPurpose    @default(CORPORATE)
  vlanId          Int? // VLAN tag (fallback if no subnet linked)
  vlanName        String? // e.g. "Corp", "Guest", "IoT"
  vlanRefId       String? // canonical Vlan link (preferred over free vlanId/vlanName)
  isHidden        Boolean        @default(false)
  clientIsolation Boolean        @default(false)
  bandSteering    Boolean        @default(false)
  isActive        Boolean        @default(true)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  controller      WifiController @relation(fields: [controllerId], references: [id], onDelete: Cascade)
  credential      Credential?    @relation("CredentialWifiNetwork", fields: [credentialId], references: [id])
  subnet          Subnet?        @relation(fields: [subnetId], references: [id])
  vlanRef         Vlan?          @relation("WifiNetworkVlan", fields: [vlanRefId], references: [id])
}

enum WifiControllerType {
  UNIFI
  MERAKI
  HP_INSTANT_ON
  GRANDSTREAM
  UBIQUITI_CLOUD
  STANDALONE
  OTHER
}

enum WifiBand {
  DUAL
  TRI
  TWO_FOUR
  FIVE
  SIX
}

enum WifiSecurity {
  WPA2_PERSONAL
  WPA2_ENTERPRISE
  WPA3_PERSONAL
  WPA3_ENTERPRISE
  WPA2_WPA3_TRANSITION
  OPEN
}

enum WifiPurpose {
  CORPORATE
  GUEST
  IOT
  VOIP
  CAMERAS
  MANAGEMENT
  OTHER
}

// ─── Wireless PTP Bridges ─────────────────────────────────────────────────────

model PtpLink {
  id            String   @id @default(cuid())
  clientId      String
  credentialId  String? // admin credential in vault
  name          String // e.g. "Main Office to Warehouse"
  make          String? // Ubiquiti, MikroTik, Cambium, etc.
  model         String? // e.g. "airMAX LiteBeam 5AC Gen2"
  frequencyBand String? // e.g. "5.8 GHz", "60 GHz", "24 GHz"
  channelWidth  String? // e.g. "40 MHz", "80 MHz"
  distanceFt    Int? // link distance in feet
  managementUrl String? // usually the master/AP-side URL
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Side A (local / near end)
  sideAName       String? // descriptive label e.g. "Main Office Rooftop"
  sideALocationId String? // link to a Location record
  sideAIp         String?
  sideAMac        String?
  sideASerial     String?
  sideASignalDbm  Int? // documented receive signal level in dBm
  sideATxPower    String? // e.g. "23 dBm", "Auto"

  // Side B (remote / far end)
  sideBName       String?
  sideBLocationId String?
  sideBIp         String?
  sideBMac        String?
  sideBSerial     String?
  sideBSignalDbm  Int?
  sideBTxPower    String?

  sideAAssetId  String?
  sideBAssetId  String?
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  credential    Credential? @relation("CredentialPtpLink", fields: [credentialId], references: [id])
  sideAAsset    Asset?      @relation("PtpLinkSideA", fields: [sideAAssetId], references: [id])
  sideBAsset    Asset?      @relation("PtpLinkSideB", fields: [sideBAssetId], references: [id])
  sideALocation Location?   @relation("PtpSideA", fields: [sideALocationId], references: [id])
  sideBLocation Location?   @relation("PtpSideB", fields: [sideBLocationId], references: [id])
}

// ─── Field History (audit trail) ──────────────────────────────────────────────

model FieldHistory {
  id         String   @id @default(cuid())
  entityType String // "asset", "networkDevice", "license"
  entityId   String
  field      String // e.g. "ipAddress", "status", "isActive"
  oldValue   String?
  newValue   String?
  changedBy  String? // staff user name
  changedAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([changedAt])
}

model PortalUser {
  id            String              @id @default(cuid())
  clientId      String
  name          String
  email         String              @unique
  passwordHash  String?
  isActive      Boolean             @default(true)
  isPortalOwner Boolean             @default(false)
  permissions   Json                @default("{}")
  lastLoginAt   DateTime?
  personId      String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  person        Person?             @relation("PortalUserPerson", fields: [personId], references: [id])
  sessions      PortalSession[]
  vaultSession  PortalVaultSession?
}

model PortalSession {
  id           String     @id @default(cuid())
  token        String     @unique
  portalUserId String
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
}

enum PortalCredentialVisibility {
  PRIVATE
  TEAM
  MSP_SHARED
}

model PortalCredential {
  id                String                     @id @default(cuid())
  clientId          String
  ownedByUserId     String?
  createdByStaffId  String?
  label             String
  username          String?
  encryptedPassword String
  encryptedTotp     String?
  url               String?
  notes             String?
  visibility        PortalCredentialVisibility @default(PRIVATE)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  client            Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  /// Free-form. Historically referenced public.PortalUser.id (DH's
  /// single-client portal model). With the merged ~/portal/ launch
  /// (Phase 2), it now holds portal.portal_users.id from the multi-
  /// client portal. The FK was dropped so both ID spaces can coexist
  /// during the migration window. Visibility filtering is by string
  /// equality.

  @@index([clientId])
  @@index([ownedByUserId])
}

model PortalVaultSession {
  id           String     @id @default(cuid())
  portalUserId String     @unique
  expiresAt    DateTime
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
}

model CustomReport {
  id          String   @id @default(cuid())
  name        String
  description String?
  entity      String
  config      Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Network Topology Diagram ──────────────────────────────────────────────────

model NetworkDiagram {
  id        String   @id @default(cuid())
  clientId  String   @unique
  xml       String   @db.Text
  updatedAt DateTime @updatedAt
  updatedBy String?
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─── Ephemeral One-Time Notes ─────────────────────────────────────────────────

model EphemeralNote {
  id               String    @id @default(cuid())
  encryptedContent String    @db.Text
  passphrase       String? // optional bcrypt hash of passphrase
  expiresAt        DateTime
  burnedAt         DateTime? // set on first read — note is then deleted async
  createdBy        String? // staff user name
  createdAt        DateTime  @default(now())
}

// ─── Secure Share Links ───────────────────────────────────────────────────────

model SecureShareLink {
  id           String   @id @default(cuid())
  resourceType String // "credential" | "document"
  resourceId   String
  passphrase   String? // optional bcrypt hash
  expiresAt    DateTime
  maxViews     Int      @default(1)
  viewCount    Int      @default(0)
  createdBy    String?
  createdAt    DateTime @default(now())
}

enum IntakeStatus {
  PENDING
  COMMITTED
  REJECTED
  FAILED
}

model IntakeSuggestion {
  id                   String       @id @default(cuid())
  clientId             String
  uploadedBy           String? // staff user email
  status               IntakeStatus @default(PENDING)
  originalName         String
  storageName          String       @unique // uuid-based filename on disk (same /uploads dir)
  mimeType             String
  size                 Int
  candidatesJson       Json? // [{ assetId?, confidence, reasoning, suggestedTitle, suggestedCategory, summary }]
  proposedNewAssetJson Json? // { category, typeName, suggestedName, make?, model?, serial?, ipAddress?, macAddress?, room?, reasoning }
  cameraActionJson     Json? // { type: "setPhoto"|"updateCamera"|"createCamera", ... }
  bulkProposalJson     Json? // discriminated union: createAssets | updateAssets | createCameras | createPhoneExtensions | createSwitchPorts
  extractedDataJson    Json? // freeform: parsed CSV rows, spotted serials, OCR snippets
  aiModel              String? // e.g. "claude-opus-4-7"
  aiTokensIn           Int?
  aiTokensOut          Int?
  aiError              String? // populated when status = FAILED
  committedDocumentId  String? // ClientDocument.id after commit
  committedAttachmentId String? // ClientAttachment.id after commit
  committedAssetId     String? // chosen asset (null means "attached unlinked")
  committedBy          String?
  committedAt          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  client               Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
  @@index([status, createdAt])
}

// ─── Internet Circuits ────────────────────────────────────────────────────────
// Documents an ISP service: static IP block, gateway, DNS, modem, edge device,
// support contacts, contract terms. Replaces flat Location.ispName/wanIp.

model InternetCircuit {
  id              String              @id @default(cuid())
  clientId        String
  locationId      String
  // identification
  label           String
  circuitId       String?
  accountNumber   String?
  serviceType     CircuitServiceType  @default(OTHER)
  role            CircuitRole         @default(PRIMARY)
  status          CircuitStatus       @default(ACTIVE)
  // ISP linkage
  vendorId        String?
  ispNameFallback String?
  supportPhone    String?
  supportEmail    String?
  portalUrl       String?
  credentialId    String?
  // bandwidth
  downloadMbps    Int?
  uploadMbps      Int?
  isSymmetric     Boolean             @default(false)
  // static IP block
  wanIp           String?
  staticBlockCidr String?
  subnetMask      String?
  gatewayIp       String?
  usableStartIp   String?
  usableEndIp     String?
  dns1            String?
  dns2            String?
  ipv6PrefixCidr  String?
  ipv6Gateway     String?
  subnetId        String?
  // hardware
  modemAssetId    String?
  edgeAssetId     String?
  // lifecycle / cost
  installDate     DateTime?
  contractStart   DateTime?
  contractEnd     DateTime?
  cancelDate      DateTime?
  monthlyCost     Float?
  // misc
  notes           String?
  legacyImported  Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  // relations
  client          Client              @relation(fields: [clientId],   references: [id], onDelete: Cascade)
  location        Location            @relation(fields: [locationId], references: [id])
  vendor          Vendor?             @relation("VendorInternetCircuits",     fields: [vendorId],     references: [id])
  modemAsset      Asset?              @relation("CircuitModemAsset",          fields: [modemAssetId], references: [id])
  edgeAsset       Asset?              @relation("CircuitEdgeAsset",           fields: [edgeAssetId],  references: [id])
  subnet          Subnet?             @relation("CircuitSubnet",              fields: [subnetId],     references: [id])
  credential      Credential?         @relation("CredentialInternetCircuit",  fields: [credentialId], references: [id])

  @@unique([locationId, label])
  @@index([clientId])
  @@index([locationId])
  @@index([vendorId])
  @@index([status])
  @@index([role])
  @@index([contractEnd])
}

enum CircuitServiceType {
  FIBER
  CABLE
  DSL
  FIXED_WIRELESS
  CELLULAR_LTE
  CELLULAR_5G
  SATELLITE
  T1
  METRO_ETHERNET
  MPLS
  SDWAN_BROADBAND
  OTHER
}

enum CircuitRole {
  PRIMARY
  FAILOVER
  LOAD_BALANCED
  OUT_OF_BAND
  GUEST
  OTHER
}

enum CircuitStatus {
  PLANNED
  ORDERED
  INSTALLING
  ACTIVE
  DEGRADED
  SUSPENDED
  CANCELLED
  RETIRED
}
